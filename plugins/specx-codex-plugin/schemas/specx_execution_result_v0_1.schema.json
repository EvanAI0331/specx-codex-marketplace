{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecX Execution Result v0.1",
  "type": "object",
  "required": [
    "result_id",
    "schema_version",
    "contract_id",
    "status",
    "executed_agents",
    "tool_calls",
    "evidence_collected",
    "gate_results",
    "artifacts",
    "verification_results",
    "failure_state",
    "risk_notes"
  ],
  "properties": {
    "result_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.1" },
    "contract_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "blocked"] },
    "executed_agents": { "type": "array" },
    "tool_calls": { "type": "array" },
    "evidence_collected": { "type": "array" },
    "gate_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "status", "evidence", "details"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "blocked"] },
          "evidence": { "type": "array" },
          "details": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "artifacts": { "type": "array" },
    "verification_results": {
      "type": "object",
      "required": ["no_fake_success", "no_silent_fallback", "explicit_failure_state"],
      "properties": {
        "no_fake_success": { "const": true },
        "no_silent_fallback": { "const": true },
        "explicit_failure_state": { "const": true }
      },
      "additionalProperties": true
    },
    "failure_state": {
      "type": ["string", "null"]
    },
    "risk_notes": { "type": "array" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "passed" } },
        "required": ["status"]
      },
      "then": {
        "properties": { "failure_state": { "enum": [null, ""] } }
      }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["failed", "blocked"] } },
        "required": ["status"]
      },
      "then": {
        "properties": { "failure_state": { "type": "string", "minLength": 1 } }
      }
    }
  ],
  "additionalProperties": true
}
