{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecX Execution Contract v0.1",
  "type": "object",
  "required": [
    "contract_id",
    "schema_version",
    "objective",
    "domain",
    "task_type",
    "required_agents",
    "required_tools",
    "required_evidence",
    "gates",
    "expected_artifacts",
    "failure_semantics",
    "execution_constraints",
    "human_approval",
    "verification_policy"
  ],
  "properties": {
    "contract_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.1" },
    "objective": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "required_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["agent_id", "role_spec", "execution_spec", "output_spec"],
        "properties": {
          "agent_id": { "type": "string", "minLength": 1 },
          "role_spec": { "type": "string", "minLength": 1 },
          "execution_spec": { "type": "string", "minLength": 1 },
          "output_spec": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "required_tools": { "type": "array", "minItems": 1 },
    "required_evidence": { "type": "array", "minItems": 1 },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gate_id", "condition", "on_pass", "on_failure"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "condition": { "type": "string", "minLength": 1 },
          "on_pass": { "type": "string", "minLength": 1 },
          "on_failure": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "expected_artifacts": { "type": "array", "minItems": 1 },
    "failure_semantics": {
      "type": "object",
      "required": ["no_fake_success", "no_silent_fallback", "explicit_failure_state"],
      "properties": {
        "no_fake_success": { "const": true },
        "no_silent_fallback": { "const": true },
        "explicit_failure_state": { "const": true }
      },
      "additionalProperties": true
    },
    "execution_constraints": {
      "type": "object",
      "required": ["no_fake_success", "no_silent_fallback", "no_hardcoded_fallback"],
      "properties": {
        "no_fake_success": { "const": true },
        "no_silent_fallback": { "const": true },
        "no_hardcoded_fallback": { "const": true }
      },
      "additionalProperties": true
    },
    "human_approval": {
      "type": "object",
      "required": ["required", "before"],
      "properties": {
        "required": { "type": "boolean" },
        "before": { "type": "array" }
      },
      "additionalProperties": true
    },
    "verification_policy": {
      "type": "object",
      "required": ["required_checks"],
      "properties": {
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "unsupported_features": { "type": "array" }
  },
  "additionalProperties": true
}
